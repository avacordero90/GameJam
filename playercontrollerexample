	if arm_sprite:
		arm_sprite.visible = not active

## Checks if there is sufficient clearance above the player to stand up
func _can_stand_up() -> bool:
	var space_state = get_world_3d().direct_space_state
	if space_state == null:
		return true
		
	# Raycast from three offset positions to cover entire player width (radius = 0.25m)
	# In this scene, the player's feet are at Y = -0.96m and standing top is at Y = +0.86m (relative to origin).
	# Cast from Y = -0.5m (crouched center) up to Y = +0.92m (standing top + safety margin)
	var offsets = [0.0, -0.2, 0.2]
	for offset in offsets:
		var query = PhysicsRayQueryParameters3D.create(
			global_position + Vector3(offset, -0.5, 0),
			global_position + Vector3(offset, 0.92, 0),
			collision_mask
		)
		query.exclude = [get_rid()]
		var result = space_state.intersect_ray(query)
		if not result.is_empty():
			return false # Obstructed!
			
	return true # All clear!
